<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
             name="Invoice" pageWidth="595" pageHeight="842"
             whenNoDataType="AllSectionsNoDetail"
             topMargin="20" bottomMargin="20" leftMargin="20" rightMargin="20">

    <parameter name="InvoiceNumber" class="java.lang.String"/>
    <parameter name="IssueDate" class="java.lang.String"/>
    <parameter name="GuestName" class="java.lang.String"/>
    <parameter name="GuestEmail" class="java.lang.String"/>
    <parameter name="GuestPhone" class="java.lang.String"/>
    <parameter name="RoomNumber" class="java.lang.String"/>
    <parameter name="RoomTypeName" class="java.lang.String"/>
    <parameter name="CheckInDate" class="java.lang.String"/>
    <parameter name="CheckOutDate" class="java.lang.String"/>
    <parameter name="Nights" class="java.lang.Integer"/>
    <parameter name="PricePerNight" class="java.math.BigDecimal"/>
    <parameter name="DiscountAmount" class="java.math.BigDecimal"/>
    <parameter name="TotalAmount" class="java.math.BigDecimal"/>
    <parameter name="Status" class="java.lang.String"/>

    <title>
        <band height="80">
            <staticText>
                <reportElement x="0" y="0" width="555" height="40"/>
                <textElement textAlignment="Center">
                    <font size="24" isBold="true"/>
                </textElement>
                <text><![CDATA[HOTEL BOOKING INVOICE]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="50" width="555" height="1"/>
            </line>
        </band>
    </title>

    <detail>
        <band height="400">
            <!-- Invoice Details Section -->
            <staticText>
                <reportElement x="0" y="10" width="555" height="20"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Invoice Details]]></text>
            </staticText>

            <textField>
                <reportElement x="20" y="35" width="250" height="18"/>
                <textFieldExpression><![CDATA["Invoice No: " + $P{InvoiceNumber}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="285" y="35" width="250" height="18"/>
                <textFieldExpression><![CDATA["Issue Date: " + $P{IssueDate}]]></textFieldExpression>
            </textField>

            <!-- Guest Info Section -->
            <staticText>
                <reportElement x="0" y="70" width="555" height="20"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Guest Information]]></text>
            </staticText>

            <textField>
                <reportElement x="20" y="95" width="555" height="18"/>
                <textFieldExpression><![CDATA["Name: " + $P{GuestName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="20" y="118" width="250" height="18"/>
                <textFieldExpression><![CDATA["Email: " + $P{GuestEmail}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="285" y="118" width="250" height="18"/>
                <textFieldExpression><![CDATA["Phone: " + $P{GuestPhone}]]></textFieldExpression>
            </textField>

            <!-- Room Info Section -->
            <staticText>
                <reportElement x="0" y="155" width="555" height="20"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Room Details]]></text>
            </staticText>

            <textField>
                <reportElement x="20" y="180" width="555" height="18"/>
                <textFieldExpression><![CDATA["Room: " + $P{RoomNumber} + " (" + $P{RoomTypeName} + ")"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="20" y="203" width="250" height="18"/>
                <textFieldExpression><![CDATA["Check-in: " + $P{CheckInDate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="285" y="203" width="250" height="18"/>
                <textFieldExpression><![CDATA["Check-out: " + $P{CheckOutDate}]]></textFieldExpression>
            </textField>

            <!-- Pricing Section -->
            <staticText>
                <reportElement x="0" y="240" width="555" height="20"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Billing]]></text>
            </staticText>

            <textField>
                <reportElement x="20" y="265" width="200" height="18"/>
                <textFieldExpression><![CDATA["Number of Nights: " + $P{Nights}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="20" y="288" width="200" height="18"/>
                <textFieldExpression><![CDATA["Price per Night: $" + String.valueOf($P{PricePerNight})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="20" y="311" width="200" height="18"/>
                <textFieldExpression><![CDATA["Discount: -$" + String.valueOf($P{DiscountAmount})]]></textFieldExpression>
            </textField>

            <!-- Total -->
            <rectangle>
                <reportElement x="350" y="295" width="205" height="40"/>
            </rectangle>
            <textField>
                <reportElement x="360" y="305" width="185" height="20"/>
                <textElement>
                    <font size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["TOTAL: $" + String.valueOf($P{TotalAmount})]]></textFieldExpression>
            </textField>

            <!-- Status -->
            <textField>
                <reportElement x="20" y="345" width="555" height="18"/>
                <textFieldExpression><![CDATA["Status: " + $P{Status}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="50">
            <staticText>
                <reportElement x="0" y="20" width="555" height="20"/>
                <textElement textAlignment="Center">
                    <font size="10" isItalic="true"/>
                </textElement>
                <text><![CDATA[Thank you for choosing our hotel!]]></text>
            </staticText>
        </band>
    </summary>
</jasperReport>